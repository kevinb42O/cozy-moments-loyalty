# ─── Supabase ───────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optioneel voor de keepalive-script of GitHub Action
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEEPALIVE_PATH=/rest/v1/site_settings?select=id&id=eq.default&limit=1

# ─── Admin authenticatie ──────────────────────────────────────────────────────────
# Komma-gescheiden lijst van admin e-mailadressen (Supabase Auth users)
VITE_ADMIN_EMAILS=admin@cozy-moments.be

# Alleen voor lokale dev ZONDER Supabase
VITE_ADMIN_PASSWORD=

# ─── QR code beveiliging ─────────────────────────────────────────────────────────
# Genereer via: openssl rand -hex 32
VITE_QR_SECRET=change-me-to-a-random-secret-string
