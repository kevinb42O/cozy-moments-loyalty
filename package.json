{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:customer\" \"npm run dev:business\"",
    "dev:clean": "npx rimraf .vite-cache && concurrently \"npm run dev:customer\" \"npm run dev:business\"",
    "dev:customer": "vite --config vite.config.customer.ts",
    "dev:business": "vite --config vite.config.business.ts",
    "build": "vite build --config vite.config.customer.ts && vite build --config vite.config.business.ts",
    "build:customer": "vite build --config vite.config.customer.ts",
    "build:business": "vite build --config vite.config.business.ts",
    "docs:manual-pdf": "node ./generate-manual-pdf.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "framer-motion": "^12.34.4",
    "html5-qrcode": "^2.3.8",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "marked": "^17.0.4",
    "puppeteer-core": "^24.38.0",
    "qrcode": "^1.5.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.1.0"
  }
}
